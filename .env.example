# Salin file ini menjadi .env saat menjalankan aplikasi.
# Jangan isi file ini dengan password asli jika akan diunggah ke GitHub.

# Server
PORT=3007
JWT_SECRET=ubah-dengan-random-secret-yang-panjang
APP_URL=http://127.0.0.1:3007

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=esuk
DB_SSLMODE=disable

# Alternatif: gunakan DATABASE_URL jika ingin satu baris koneksi database.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/esuk?sslmode=disable

# Hanya untuk darurat lokal. Di production biarkan false.
ALLOW_NO_DB=false
