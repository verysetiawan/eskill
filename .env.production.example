# Contoh konfigurasi production server sekolah.
# Salin ke /etc/eskill/eskill.env atau .env di folder aplikasi server.

PORT=3007
APP_URL=https://eskill.namasekolah.sch.id
JWT_SECRET=ganti-dengan-secret-random-minimal-32-karakter

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=eskill
DB_PASSWORD=ganti-dengan-password-database-kuat
DB_NAME=eskill
DB_SSLMODE=disable

ALLOW_NO_DB=false
