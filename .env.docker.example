# Salin menjadi .env.docker sebelum menjalankan docker compose.

# Port aplikasi di host/server.
APP_PORT=3007
APP_URL=http://127.0.0.1:3007

# Secret login/JWT. Ganti dengan teks random panjang.
JWT_SECRET=ganti-dengan-secret-random-minimal-32-karakter

# Database PostgreSQL container.
POSTGRES_DB=eskill
POSTGRES_USER=eskill
POSTGRES_PASSWORD=ganti-dengan-password-database-kuat

TZ=Asia/Jakarta
